# ----------------------------------------------------------------------------
# Bungie API configuratie
# Maak een app aan op https://www.bungie.net/en/Application en kopieer de waarden.
# Kopieer dit bestand naar `.env.local` en vul je echte waarden in.
# `.env.local` staat in .gitignore en wordt dus NOOIT gecommit.
# ----------------------------------------------------------------------------

# Verplicht voor alle API-calls (publieke game-data + OAuth).
BUNGIE_API_KEY=your_api_key_here

# Nodig voor OAuth login (eigen account / characters / inventory).
# OAuth Client Type = "Confidential" geeft je zowel een ID als een Secret.
BUNGIE_CLIENT_ID=your_client_id_here
BUNGIE_CLIENT_SECRET=your_client_secret_here

# Moet exact overeenkomen met de "Redirect URL" in je Bungie app-instellingen.
# Voor lokaal (Bungie vereist https, ook op localhost):
# https://localhost:3000/api/auth/callback
BUNGIE_REDIRECT_URI=https://localhost:3000/api/auth/callback

# Willekeurige lange string voor het versleutelen/ondertekenen van sessie-cookies.
# Genereer er een met: openssl rand -hex 32
SESSION_SECRET=change_me_to_a_long_random_string
